# xapi.to Token（必填）— 申请地址：https://www.xapi.to/
XAPI_TOKEN=your_xapi_token_here

# OpenAI API Key（必填）
OPENAI_API_KEY=your_openai_key_here
# OpenAI-compatible base URL（如 PackyAPI，可选）
OPENAI_BASE_URL=
# OpenAI-compatible model（如 gpt-5.4-high，可选）
OPENAI_MODEL=

# Brave Search API Key（必填）— 免费2000次/月
BRAVE_API_KEY=your_brave_key_here
